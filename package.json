{
  "name": "antdv-next-x-workspace",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antdv-next/x.git"
  },
  "type": "module",
  "scripts": {
    "dev:play": "vp dev packages/playground",
    "docs:dev": "vp dev packages/docs",
    "docs:preview": "vp preview packages/docs",
    "docs:build": "vp run --filter @antdv-next/docs build",
    "docs:llm": "vp run --filter @antdv-next/docs build:llm",
    "docs:llm:text": "vp run --filter @antdv-next/docs build:llm:text",
    "docs:llm:semantic": "vp run --filter @antdv-next/docs build:llm:semantic",
    "test:unit": "vp test",
    "type-check": "vp run --filter \"./packages/*\" --filter \"!./packages/docs\" type-check",
    "build": "vp run --filter \"./packages/*\" --filter \"!./packages/x-skill\" build",
    "build:packages": "vp run --filter \"./packages/*\" --filter \"!./packages/docs\" --filter \"!./packages/x-skill\" build",
    "build:docs": "vp run --filter @antdv-next/docs build",
    "build:x": "vp run --filter @antdv-next/x build",
    "build:token": "vp run --filter @antdv-next/x build:token",
    "pack:packages": "vp pm pack -r --filter \"./packages/*\" --filter \"!./packages/docs\"",
    "publish:packages": "vp pm publish -r --filter \"./packages/*\" --filter \"!./packages/docs\" --access public --no-git-checks",
    "publish:x": "vp run --filter @antdv-next/x build && vp pm publish --filter @antdv-next/x --access public --no-git-checks",
    "publish:x-markdown": "vp run --filter @antdv-next/x-markdown build && vp pm publish --filter @antdv-next/x-markdown --access public --no-git-checks",
    "publish:x-sdk": "vp run --filter @antdv-next/x-sdk build && vp pm publish --filter @antdv-next/x-sdk --access public --no-git-checks",
    "publish:x-skill": "vp run --filter @antdv-next/x-skill build && vp pm publish --filter @antdv-next/x-skill --access public --no-git-checks",
    "publish:x-card": "vp run --filter @antdv-next/x-card build && vp pm publish --filter @antdv-next/x-card --access public --no-git-checks",
    "bump:x": "vp exec bumpp packages/x/package.json --tag --tag-prefix \"@antdv-next/x@\"",
    "bump:x-markdown": "vp exec bumpp packages/x-markdown/package.json --tag --tag-prefix \"@antdv-next/x-markdown@\"",
    "bump:x-sdk": "vp exec bumpp packages/x-sdk/package.json --tag --tag-prefix \"@antdv-next/x-sdk@\"",
    "bump:x-skill": "vp exec bumpp packages/x-skill/package.json --tag --tag-prefix \"@antdv-next/x-skill@\"",
    "bump:x-card": "vp exec bumpp packages/x-card/package.json --tag --tag-prefix \"@antdv-next/x-card@\"",
    "bump:all": "vp exec bumpp --all",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@antdv-next/icons": "catalog:prod",
    "@antdv-next/unocss": "catalog:docs",
    "@tsconfig/node24": "catalog:dev",
    "@types/jsdom": "catalog:types",
    "@types/node": "catalog:types",
    "@types/picomatch": "catalog:types",
    "@v-c/util": "catalog:prod",
    "@vitejs/plugin-vue": "catalog:dev",
    "@vitejs/plugin-vue-jsx": "catalog:dev",
    "@vue/language-core": "catalog:dev",
    "@vue/test-utils": "catalog:dev",
    "@vue/tsconfig": "catalog:dev",
    "@vueuse/core": "catalog:prod",
    "antdv-next": "catalog:prod",
    "bumpp": "catalog:dev",
    "dayjs": "catalog:prod",
    "jiti": "catalog:dev",
    "jsdom": "catalog:dev",
    "lru-cache": "catalog:prod",
    "mlly": "catalog:prod",
    "nanoid": "catalog:prod",
    "npm-run-all2": "catalog:dev",
    "pathe": "catalog:prod",
    "picomatch": "catalog:prod",
    "postcss-selector-parser": "catalog:dev",
    "tinyglobby": "catalog:dev",
    "typedoc": "catalog:dev",
    "typescript": "catalog:dev",
    "unocss": "catalog:docs",
    "unplugin-auto-import": "catalog:dev",
    "unplugin-dts": "catalog:dev",
    "unplugin-vue-components": "catalog:dev",
    "vite": "catalog:",
    "vite-plugin-dayjs": "catalog:dev",
    "vite-plugin-inspect": "catalog:dev",
    "vite-plugin-tsx-resolve-types": "catalog:dev",
    "vite-plugin-vue-devtools": "catalog:dev",
    "vite-plugin-vue-resolve-types": "catalog:dev",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:prod",
    "vue-i18n": "catalog:prod",
    "vue-router": "catalog:prod",
    "vue-tsc": "catalog:dev"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.32.1"
}
