{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "rootDir": "src",
    "noEmit": true,
    "outDir": "dist",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
