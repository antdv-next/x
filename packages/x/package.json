{
  "name": "@antdv-next/x",
  "type": "module",
  "version": "0.0.1",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "./dist/*.css",
    "./dist/index.esm.js",
    "./dist/index.umd.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.js"
    },
    "./global.d.ts": "./global.d.ts",
    "./global": "./global.d.ts",
    "./package.json": "./package.json",
    "./dist/index.esm.js": "./dist/index.esm.js",
    "./dist/index.umd.js": "./dist/index.umd.js"
  },
  "main": "dist/index.js",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "global.d.ts"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "type-check": "vue-tsc --project tsconfig.app.json --noEmit",
    "build:comp": "vite build --config vite.build.config.ts",
    "build:esm": "vite build --config vite.esm.config.ts",
    "build:umd": "vite build --config vite.umd.config.ts",
    "build": "pnpm run build:comp && pnpm run build:esm && pnpm run build:umd"
  },
  "peerDependencies": {
    "antdv-next": ">=1.0.0",
    "vue": ">=3.5.0"
  },
  "dependencies": {
    "@antdv-next/icons": "catalog:prod",
    "@vueuse/core": "catalog:prod",
    "antdv-next": "catalog:prod",
    "@antdv-next/cssinjs": "catalog:prod",
    "@ant-design/fast-color": "catalog:prod",
    "dayjs": "catalog:prod",
    "vue": "catalog:prod"
  }
}
